{
  "name": "@loopy/cli",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "loopy": "./dist/esm/index.js"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json --outDir ./dist/cjs && tsc -p tsconfig.esm.json && node ../../scripts/add-js-extensions.mjs",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "clean": "rm -rf dist",
    "lint": "oxlint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@loopy/core": "workspace:*",
    "@loopy/gh": "workspace:*",
    "@loopy/opencode": "workspace:*",
    "chalk": "^4.1.2",
    "commander": "^15.0.0",
    "jiti": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  }
}