{
  "name": "@loopy/core",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json --outDir ./dist/cjs && tsc -p tsconfig.esm.json && node ../../scripts/add-js-extensions.mjs",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "clean": "rm -rf dist",
    "lint": "oxlint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "simple-git": "^3.36.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  }
}