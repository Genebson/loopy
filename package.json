{
  "name": "loopy-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Loopy — local CLI loop runner",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm --filter @loopy/core build && pnpm --filter @loopy/gh build && pnpm --filter @loopy/opencode build && pnpm --filter @loopy/test-utils build && pnpm --filter @loopy/cli build",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules && pnpm -r run clean",
    "e2e": "echo 'No e2e tests yet'"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "oxlint": "^1.57.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}